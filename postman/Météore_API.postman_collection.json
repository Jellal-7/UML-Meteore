    {
      "name": "5. Réservations + Paiements",
      "description": "Ordre critique : Créer → Payer → Consulter paiement → Créer 2e booking → Annuler 2e booking",
      "item": [
        {
          "name": "Créer une réservation (2 passagers)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Statut initial = pending', () => pm.expect(res.booking.status).to.eql('pending'));",
                  "pm.test('Passagers créés', () => pm.expect(res.booking.Passengers.length).to.eql(2));",
                  "pm.test('Prix total calculé', () => pm.expect(parseFloat(res.booking.total_price)).to.be.greaterThan(0));",
                  "pm.collectionVariables.set('bookingId', res.booking.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"flight_id\": {{flightId}},\n  \"passengers\": [\n    {\n      \"first_name\": \"Jean\",\n      \"last_name\": \"Dupont\",\n      \"birth_date\": \"1990-05-15\",\n      \"passport_number\": \"FR12345678\"\n    },\n    {\n      \"first_name\": \"Marie\",\n      \"last_name\": \"Dupont\",\n      \"birth_date\": \"1992-08-20\",\n      \"passport_number\": \"FR87654321\"\n    }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
          }
        },
        {
          "name": "Payer la réservation (simulation CB)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200 ou 201', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));",
                  "pm.test('Paiement complété', () => pm.expect(res.payment.status).to.eql('completed'));",
                  "pm.test('Booking confirmé', () => pm.expect(res.booking.status).to.eql('confirmed'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"card_number\": \"4111111111111111\",\n  \"card_holder\": \"Jean Dupont\",\n  \"card_expiry\": \"1228\",\n  \"card_cvv\": \"123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/payments/{{bookingId}}/pay", "host": ["{{baseUrl}}"], "path": ["payments", "{{bookingId}}", "pay"] }
          }
        },
        {
          "name": "Consulter le paiement",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Retourne le paiement', () => pm.expect(res.payment).to.have.property('amount'));",
                  "pm.test('Statut completed', () => pm.expect(res.payment.status).to.eql('completed'));"
                ]
