{
  "info": {
    "name": "Météore API",
    "description": "Collection complète de l'API REST Météore — plateforme de réservation de vols.\n\nVariables :\n- {{baseUrl}} : URL de l'API (local ou production)\n- {{token}} : JWT récupéré automatiquement après login\n- {{adminToken}} : JWT admin récupéré automatiquement après login admin",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://uml-meteore.onrender.com/api" },
    { "key": "token", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "flightId", "value": "" },
    { "key": "bookingId", "value": "" },
    { "key": "airportId", "value": "" },
    { "key": "airlineId", "value": "" }
  ],
  "item": [
    {
      "name": "1. Authentification",
      "item": [
        {
          "name": "Register — Créer un compte",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const timestamp = Date.now();",
                  "const randomEmail = `test.user.${timestamp}@example.com`;",
                  "pm.collectionVariables.set('registerEmail', randomEmail);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Retourne un token JWT', () => pm.expect(res.token).to.be.a('string'));",
                  "pm.test('Retourne les infos utilisateur', () => {",
                  "  pm.expect(res.user).to.have.property('email');",
                  "  pm.expect(res.user).to.have.property('first_name');",
                  "});",
                  "if (res.token) pm.collectionVariables.set('token', res.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Test\",\n  \"last_name\": \"Utilisateur\",\n  \"email\": \"{{registerEmail}}\",\n  \"password\": \"motdepasse123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Login — Connexion utilisateur",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Retourne un token JWT', () => pm.expect(res.token).to.be.a('string'));",
                  "pm.test('Retourne le rôle user', () => pm.expect(res.user.role).to.eql('user'));",
                  "if (res.token) pm.collectionVariables.set('token', res.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jean.dupont@email.com\",\n  \"password\": \"user123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login Admin — Connexion administrateur",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Retourne un token JWT', () => pm.expect(res.token).to.be.a('string'));",
                  "pm.test('Retourne le rôle admin', () => pm.expect(res.user.role).to.eql('admin'));",
                  "if (res.token) pm.collectionVariables.set('adminToken', res.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@meteore.fr\",\n  \"password\": \"admin123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login — Identifiants incorrects (test erreur)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "pm.test('Message générique (ne révèle pas si email ou mot de passe)', () => {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.error).to.include('incorrect');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@meteore.fr\",\n  \"password\": \"mauvais_mot_de_passe\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "GET /auth/me — Profil utilisateur connecté",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Retourne le profil sans password_hash', () => {",
                  "  pm.expect(res.user).to.have.property('email');",
                  "  pm.expect(res.user).to.not.have.property('password_hash');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "GET /auth/me — Sans token (test 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "PUT /auth/profile — Modifier le profil",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Profil mis à jour', () => {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.user.first_name).to.eql('Jean-Updated');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Jean-Updated\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/profile", "host": ["{{baseUrl}}"], "path": ["auth", "profile"] }
          }
        }
      ]
    },
    {
      "name": "2. Vols",
      "item": [
        {
          "name": "Rechercher des vols — sans filtres",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Retourne un tableau de vols', () => pm.expect(res.flights).to.be.an('array'));",
                  "pm.test('Au moins 1 vol retourné', () => pm.expect(res.flights.length).to.be.greaterThan(0));",
                  "if (res.flights.length > 0) pm.collectionVariables.set('flightId', res.flights[0].id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/flights/search", "host": ["{{baseUrl}}"], "path": ["flights", "search"] }
          }
        },
        {
          "name": "Rechercher des vols — CDG → JFK",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Retourne des vols', () => pm.expect(res.flights).to.be.an('array'));",
                  "if (res.flights.length > 0) {",
                  "  pm.test('Vol au départ de CDG', () => pm.expect(res.flights[0].departureAirport.iata_code).to.eql('CDG'));",
                  "  pm.collectionVariables.set('flightId', res.flights[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/flights/search?from=CDG&to=JFK&passengers=1&sort=price",
              "host": ["{{baseUrl}}"],
              "path": ["flights", "search"],
              "query": [
                { "key": "from", "value": "CDG" },
                { "key": "to", "value": "JFK" },
                { "key": "passengers", "value": "1" },
                { "key": "sort", "value": "price" }
              ]
            }
          }
        },
        {
          "name": "Rechercher des vols — filtre prix max 200€",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Tous les vols sont ≤ 200€', () => {",
                  "  res.flights.forEach(f => pm.expect(parseFloat(f.price)).to.be.at.most(200));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/flights/search?price_max=200&sort=price",
              "host": ["{{baseUrl}}"],
              "path": ["flights", "search"],
              "query": [
                { "key": "price_max", "value": "200" },
                { "key": "sort", "value": "price" }
              ]
            }
          }
        },
        {
          "name": "Détail d'un vol",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Retourne le vol avec ses relations', () => {",
                  "  pm.expect(res.flight).to.have.property('flight_number');",
                  "  pm.expect(res.flight).to.have.property('Airline');",
                  "  pm.expect(res.flight).to.have.property('departureAirport');",
                  "  pm.expect(res.flight).to.have.property('arrivalAirport');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/flights/{{flightId}}", "host": ["{{baseUrl}}"], "path": ["flights", "{{flightId}}"] }
          }
        },
        {
          "name": "Admin — Créer un vol",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Vol créé avec le bon numéro', () => pm.expect(res.flight.flight_number).to.eql('TEST01'));",
                  "pm.collectionVariables.set('testFlightId', res.flight.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"flight_number\": \"TEST01\",\n  \"airline_id\": 1,\n  \"departure_airport_id\": 1,\n  \"arrival_airport_id\": 3,\n  \"departure_at\": \"2026-06-15T08:00:00.000Z\",\n  \"arrival_at\": \"2026-06-15T17:00:00.000Z\",\n  \"price\": 999.99,\n  \"available_seats\": 50,\n  \"total_seats\": 100,\n  \"status\": \"scheduled\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/flights", "host": ["{{baseUrl}}"], "path": ["flights"] }
          }
        },
        {
          "name": "Admin — Modifier un vol",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Prix mis à jour', () => pm.expect(parseFloat(pm.response.json().flight.price)).to.eql(1099.99));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 1099.99\n}"
            },
            "url": { "raw": "{{baseUrl}}/flights/{{testFlightId}}", "host": ["{{baseUrl}}"], "path": ["flights", "{{testFlightId}}"] }
          }
        },
        {
          "name": "Admin — Supprimer un vol (sans réservations)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 204', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/flights/{{testFlightId}}", "host": ["{{baseUrl}}"], "path": ["flights", "{{testFlightId}}"] }
          }
        },
        {
          "name": "User — Créer un vol (test 403 Forbidden)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403 — rôle insuffisant', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"flight_number\": \"HACK01\",\n  \"airline_id\": 1,\n  \"departure_airport_id\": 1,\n  \"arrival_airport_id\": 2,\n  \"departure_at\": \"2026-06-01T08:00:00.000Z\",\n  \"arrival_at\": \"2026-06-01T10:00:00.000Z\",\n  \"price\": 1,\n  \"available_seats\": 1,\n  \"total_seats\": 1\n}"
            },
            "url": { "raw": "{{baseUrl}}/flights", "host": ["{{baseUrl}}"], "path": ["flights"] }
          }
        }
      ]
    },
    {
      "name": "3. Aéroports",
      "item": [
        {
          "name": "Lister tous les aéroports",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Retourne 8 aéroports', () => pm.expect(res.airports.length).to.eql(8));",
                  "pm.test('Chaque aéroport a un code IATA', () => {",
                  "  res.airports.forEach(a => pm.expect(a.iata_code).to.have.lengthOf(3));",
                  "});",
                  "if (res.airports.length > 0) pm.collectionVariables.set('airportId', res.airports[0].id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/airports", "host": ["{{baseUrl}}"], "path": ["airports"] }
          }
        },
        {
          "name": "Admin — Créer un aéroport",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Code IATA correct', () => pm.expect(res.airport.iata_code).to.eql('TST'));",
                  "pm.collectionVariables.set('testAirportId', res.airport.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Airport\",\n  \"iata_code\": \"TST\",\n  \"city\": \"Testville\",\n  \"country\": \"France\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/airports", "host": ["{{baseUrl}}"], "path": ["airports"] }
          }
        },
        {
          "name": "Admin — Supprimer un aéroport",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 204', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/airports/{{testAirportId}}", "host": ["{{baseUrl}}"], "path": ["airports", "{{testAirportId}}"] }
          }
        }
      ]
    },
