    {
      "name": "5. Réservations",
      "item": [
        {
          "name": "Créer une réservation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Statut initial = pending', () => pm.expect(res.booking.status).to.eql('pending'));",
                  "pm.test('Passagers créés', () => pm.expect(res.booking.Passengers.length).to.eql(2));",
                  "pm.test('Prix total calculé', () => pm.expect(parseFloat(res.booking.total_price)).to.be.greaterThan(0));",
                  "pm.collectionVariables.set('bookingId', res.booking.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"flight_id\": {{flightId}},\n  \"passengers\": [\n    {\n      \"first_name\": \"Jean\",\n      \"last_name\": \"Dupont\",\n      \"birth_date\": \"1990-05-15\",\n      \"passport_number\": \"FR12345678\"\n    },\n    {\n      \"first_name\": \"Marie\",\n      \"last_name\": \"Dupont\",\n      \"birth_date\": \"1992-08-20\",\n      \"passport_number\": \"FR87654321\"\n    }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
          }
        },
        {
          "name": "Mes réservations",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Retourne un tableau', () => pm.expect(res.bookings).to.be.an('array'));",
                  "pm.test('Au moins 1 réservation', () => pm.expect(res.bookings.length).to.be.greaterThan(0));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/bookings/my", "host": ["{{baseUrl}}"], "path": ["bookings", "my"] }
          }
        },
        {
          "name": "Détail d'une réservation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Contient les passagers', () => pm.expect(res.booking.Passengers).to.be.an('array'));",
                  "pm.test('Contient le vol', () => pm.expect(res.booking.Flight).to.have.property('flight_number'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/bookings/{{bookingId}}", "host": ["{{baseUrl}}"], "path": ["bookings", "{{bookingId}}"] }
          }
        },
        {
          "name": "Admin — Toutes les réservations (paginé)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Retourne bookings + pagination', () => {",
                  "  pm.expect(res.bookings).to.be.an('array');",
