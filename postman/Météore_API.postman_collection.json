                  "const flightId = pm.collectionVariables.get('flightId');",
                  "pm.sendRequest({",
                  "  url: baseUrl + '/bookings',",
                  "  method: 'POST',",
                  "  header: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },",
                  "  body: { mode: 'raw', raw: JSON.stringify({ flight_id: parseInt(flightId), passengers: [{ first_name: 'Card', last_name: 'Test', birth_date: '1990-01-01', passport_number: 'XX000' }] }) }",
                  "}, (err, res) => {",
                  "  const data = res.json();",
                  "  pm.collectionVariables.set('blacklistBookingId', data.booking.id);",
                  "});"
                ]
              }
            },
